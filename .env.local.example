# Copy this file to .env.local and replace CHANGE_ME before running Compose.
# Use a URL-safe password because Compose builds the API database URL from these values.
POSTGRES_USER=catalogguard_local
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=catalogguard_lite

# Host ports avoid the common Windows PostgreSQL 5432 and API 8000 conflicts.
POSTGRES_HOST_PORT=5433
API_HOST_PORT=8001
