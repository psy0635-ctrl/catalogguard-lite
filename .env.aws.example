# Copy these names into a secret file outside the repository on EC2.
# DATABASE_URL must use a dedicated application user, not the RDS master user.
# Percent-encode reserved characters in the password before placing it in the URL.
DATABASE_URL=

# Staging must verify both RDS TLS encryption and the server certificate hostname.
PGSSLMODE=verify-full
PGSSLROOTCERT=/run/secrets/rds-ca-bundle.pem

# Do not put AWS access keys here. Attach an IAM role to EC2 instead.
# TEST_DATABASE_URL is a test-only setting and must remain unset on EC2.
